 "html": "<h2 style=\"text-align:center;\">EMI Payment History</h2>\n\n<p><b>Loan Application ID:</b> {{ doc.loan_application_id }}</p>\n<p><b>Total Paid:</b> \u20b9 {{ doc.amount_paid }}</p>\n<p><b>Pending Amount:</b> \u20b9 {{ doc.pending_amount }}</p>\n\n<br>\n\n<table border=\"1\" style=\"width:100%; border-collapse: collapse;\">\n    <thead>\n        <tr>\n            <th>Date</th>\n            <th>Payment Amount</th>\n            <th>Principal</th>\n            <th>Interest</th>\n            <th>Penalty</th>\n            <th>Mode</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for row in doc.payment_history %}\n        <tr>\n            <td>{{ row.payment_date }}</td>\n            <td>{{ row.payment_amount }}</td>\n            <td>{{ row.principal_paid }}</td>\n            <td>{{ row.interest_paid }}</td>\n            <td>{{ row.penalty_amount }}</td>\n            <td>{{ row.payment_mode }}</td>\n        </tr>\n        {% endfor %}\n    </tbody>\n</table>",
