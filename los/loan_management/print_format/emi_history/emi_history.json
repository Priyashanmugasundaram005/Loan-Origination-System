 "html": "<style>\n    .bank-header {\n        text-align: center;\n        border-bottom: 2px solid #000;\n        padding-bottom: 10px;\n        margin-bottom: 15px;\n    }\n\n    .bank-header h1 {\n        margin: 0;\n        font-size: 22px;\n        letter-spacing: 1px;\n    }\n\n    .bank-header p {\n        margin: 2px 0;\n        font-size: 12px;\n        color: #555;\n    }\n\n    .report-title {\n        text-align: center;\n        font-size: 18px;\n        font-weight: bold;\n        margin: 15px 0;\n        text-transform: uppercase;\n    }\n\n    .summary-box {\n        width: 100%;\n        margin-bottom: 15px;\n        border: 1px solid #ccc;\n        padding: 10px;\n        font-size: 13px;\n    }\n\n    .summary-row {\n        display: flex;\n        justify-content: space-between;\n        margin: 4px 0;\n    }\n\n    table {\n        width: 100%;\n        border-collapse: collapse;\n        font-size: 12px;\n    }\n\n    th {\n        background-color: #f2f2f2;\n        padding: 8px;\n        border: 1px solid #ccc;\n        text-align: center;\n    }\n\n    td {\n        padding: 6px;\n        border: 1px solid #ccc;\n        text-align: center;\n    }\n\n    .amount {\n        text-align: right;\n    }\n\n    .footer {\n        margin-top: 20px;\n        font-size: 11px;\n        text-align: right;\n        color: #777;\n    }\n</style>\n\n{% set loan = frappe.get_doc(\"Loan Application\", doc.loan_application_id) %}\n{% set bank = frappe.get_doc(\"Bank\", loan.bank_name,ignore_permissions=True) %}\n{% set branch = frappe.get_doc(\"Branch\", loan.branch_name) %}\n\n<div style=\"position:relative;\">\n    <div style=\"position:absolute; right:0; top:-30px;\">\n            <img src=\"{{ frappe.utils.get_url(bank.bank_logo) }}\" style=\"height:80px;\">\n    </div>\n\n</div>\n\n<div class=\"bank-header\">\n    <h1>{{ bank.bank_name }}</h1>\n    <p>{{ branch.branch_address }}</p>\n</div>\n\n<div class=\"report-title\">\n    EMI Payment Statement\n</div>\n\n<div class=\"summary-box\">\n    <div class=\"summary-row\">\n        <span><b>Loan Application ID:</b> {{ doc.loan_application_id }}</span>\n    </div>\n    <div class=\"summary-row\">\n        <span><b>Loan Amount:</b> \u20b9 {{ frappe.utils.fmt_money(doc.loan_amount) }}</span>\n        <span><b>Date:</b> {{ frappe.utils.formatdate(frappe.utils.nowdate()) }}</span>\n        \n    </div>\n    <div class=\"summary-row\">\n        <span><b>Total Paid:</b> \u20b9 {{ frappe.utils.fmt_money(doc.amount_paid) }}</span>\n        <span><b>Pending Amount:</b> \u20b9 {{ frappe.utils.fmt_money(doc.pending_amount) }}</span\n    </div>\n</div>\n\n<table>\n    <thead>\n        <tr>\n            <th>#</th>\n            <th>Payment Date</th>\n            <th>Due Date</th>\n            <th>Payment Type</th>\n            <th>Amount</th>\n            <th>Principal</th>\n            <th>Interest</th>\n            <th>Extra</th>\n            <th>Pending</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for row in doc.emi_payment_history %}\n        <tr>\n            <td>{{ loop.index }}</td>\n            <td>{{ frappe.utils.format_datetime(row.payment_date) }}</td>\n            <td>{{ frappe.utils.formatdate(row.due_date) }}</td>\n            <td>{{ row.payment_type }}</td>\n            <td class=\"amount\">\u20b9 {{ frappe.utils.fmt_money(row.amount) }}</td>\n            <td class=\"amount\">\u20b9 {{ frappe.utils.fmt_money(row.principal) }}</td>\n            <td class=\"amount\">\u20b9 {{ frappe.utils.fmt_money(row.interest) }}</td>\n            <td class=\"amount\">\u20b9 {{ frappe.utils.fmt_money(row.extra_payment) }}</td>\n            <td class=\"amount\">\u20b9 {{ frappe.utils.fmt_money(row.pending_due_amount) }}</td>\n        </tr>\n        {% endfor %}\n    </tbody>\n</table>\n\n<div class=\"footer\">\n    This is a system generated statement. No signature required.\n</div>",
