 "font_size": 14,
 "html": "<style>\n    body {\n        font-family: Arial, sans-serif;\n        font-size: 13px;\n        line-height: 1.6;\n    }\n\n    .header {\n        text-align: center;\n        margin-bottom: 20px;\n    }\n\n    .header h2 {\n        margin-bottom: 5px;\n    }\n\n    .section-title {\n        margin-top: 25px;\n        margin-bottom: 10px;\n        font-size: 15px;\n        font-weight: bold;\n        border-bottom: 1px solid #000;\n        padding-bottom: 3px;\n    }\n\n    .details-table {\n        width: 100%;\n        border-spacing: 0 8px; /* adds vertical spacing */\n    }\n\n    .details-table td {\n        padding: 6px 10px;\n        vertical-align: top;\n    }\n\n    .data-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 10px;\n    }\n\n    .data-table th, .data-table td {\n        border: 1px solid #000;\n        padding: 8px;\n        text-align: left;\n    }\n\n    .data-table th {\n        background-color: #f5f5f5;\n    }\n\n    .spacer {\n        height: 15px;\n    }\n</style>\n\n<div class=\"header\">\n    <h2>{{ doc.bank_name }}</h2>\n    <p>{{ frappe.db.get_value(\"Branch\", doc.branch_name, \"branch_address\") }}</p>\n</div>\n\n<div class=\"section-title\">Applicant Details</div>\n<table class=\"details-table\">\n    <tr>\n        <td><b>Applicant ID:</b> {{ doc.applicant_id }}</td>\n        <td><b>Applicant Name:</b> {{ doc.applicant_name }}</td>\n    </tr>\n    <tr>\n        <td><b>Account No:</b> {{ doc.account_number }}</td>\n        <td><b>Address:</b> {{ doc.applicant_address }}</td>\n    </tr>\n</table>\n\n<div class=\"section-title\">Loan Details</div>\n<table class=\"details-table\">\n    <tr>\n        <td><b>Loan Category:</b> \n            {{ frappe.db.get_value(\"Loan Product Category\", doc.loan_product_type, \"category_name\") }}\n        </td>\n        <td><b>Loan Product:</b> \n            {{ frappe.db.get_value(\"Loan Product\", doc.loan_product, \"product_name\") }}\n        </td>\n    </tr>\n    <tr>\n        <td><b>Requested Amount:</b> {{ doc.requesting_amount }}</td>\n        <td><b>Sanctioned Amount:</b> {{ doc.sanction_amount }}</td>\n    </tr>\n    <tr>\n        <td><b>Interest Rate:</b> {{ doc.interest_rate }} %</td>\n        <td><b>Tenure:</b> {{ doc.tenure }} months</td>\n    </tr>\n</table>\n\n<div class=\"section-title\">Joint Applicants</div>\n<table class=\"data-table\">\n    <tr>\n        <th>Name</th>\n        <th>Account Number</th>\n        <th>Phone Number</th>\n    </tr>\n    {% for row in doc.joint_applicants %}\n    <tr>\n        <td>{{ row.joint_applicant_name }}</td>\n        <td>{{ row.account_number }}</td>\n        <td>{{ row.phone_number }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<div class=\"section-title\">Nominee Details</div>\n<table class=\"data-table\">\n    <tr>\n        <th>Nominee Name</th>\n        <th>Relation</th>\n        <th>Share (%)</th>\n    </tr>\n    {% for row in doc.nominees %}\n    <tr>\n        <td>{{ row.nominee_name }}</td>\n        <td>{{ row.relation }}</td>\n        <td>{{ row.share_percent }}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<div class=\"spacer\"></div>\n\n<table style=\"width:100%; margin-top:30px;\">\n    <tr>\n        <td><b>Date:</b> {{ frappe.utils.nowdate() }}</td>\n        <td style=\"text-align:right;\"><b>Authorized Signature</b></td>\n    </tr>\n</table>",
